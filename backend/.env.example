PORT=4000
# Opcion recomendada en cloud: URL completa (ej. Railway MYSQL_PUBLIC_URL)
# Si defines DB_URL, no necesitas DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME.
# DB_URL=mysql://user:password@host:3306/database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password
DB_NAME=work_reports_db
NODE_ENV=development
API_KEY=CAMBIA_ESTA_API_KEY_POR_UNA_LARGA_Y_SEGURA
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
DB_CONNECT_TIMEOUT_MS=10000
# Para produccion (TLS MySQL): ruta al certificado CA
# DB_SSL_CA=C:/ruta/ca.pem
